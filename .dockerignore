# Keep the build context small and never bake local cruft or weights into the image.
.git
.github
.venv
venv
env
__pycache__
*.py[cod]
.pytest_cache
.ruff_cache
.mypy_cache

# Trained weights are never shipped in the image (they're gitignored too).
corpora/**/checkpoints
*.pt
*.pth
*.ckpt
*.bin

.DS_Store
.idea
.vscode
